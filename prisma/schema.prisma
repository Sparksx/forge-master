generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int      @id @default(autoincrement())
  username       String   @unique @db.VarChar(30)
  email          String?  @unique
  passwordHash   String?
  isGuest        Boolean  @default(false)
  googleId       String?  @unique
  discordId      String?  @unique
  profilePicture String   @default("wizard") @db.VarChar(30)
  role           String   @default("user") @db.VarChar(20) // "user" | "moderator" | "admin"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  pvpRating      Int      @default(1000)
  pvpWins        Int      @default(0)
  pvpLosses      Int      @default(0)
  settings       Json     @default("{}")

  gameState      GameState?
  sentMessages   ChatMessage[]  @relation("sender")
  conversations  ConversationMember[]

  @@index([pvpRating])
  @@index([createdAt])
  refreshTokens  RefreshToken[]
  bans           Ban[]          @relation("bannedUser")
  mutes          Mute[]         @relation("mutedUser")
  warnings       Warning[]      @relation("warnedUser")
  issuedWarnings Warning[]      @relation("warningIssuer")
  auditLogs      AuditLog[]     @relation("auditActor")
  purchases      Purchase[]
  clanMembership ClanMember?
  expeditionEntries    ExpeditionMember[]
  missionContributions MissionContribution[]
}

model Clan {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(30)
  tag         String   @unique @db.VarChar(5)
  emblem      String   @default("⚔️") @db.VarChar(10)
  description String   @default("") @db.VarChar(200)
  treasury    Int      @default(0) // gold "clan bank" — funds expeditions, NOT level (non-power)
  xp          Int      @default(0) // clan experience — drives clan level (earned by playing together)
  ownerId     Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     ClanMember[]
  expeditions Expedition[]
  missions    Mission[]

  @@index([treasury])
  @@index([xp])
}

model ClanMember {
  id            Int      @id @default(autoincrement())
  clanId        Int
  clan          Clan     @relation(fields: [clanId], references: [id], onDelete: Cascade)
  userId        Int      @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role          String   @default("member") @db.VarChar(20) // rank key: owner | coleader | officer | member
  contributed   Int      @default(0) // gold donated to the treasury
  xpContributed Int      @default(0) // clan XP this member generated (expeditions + missions)
  joinedAt      DateTime @default(now())

  @@index([clanId])
}

// A timed cooperative activity. A privileged member launches it; members register
// into a limited number of slots; when the timer ends it resolves (success rolled
// from registered members' combined power) and pays clan XP + per-member gold.
// NOTE: expeditions are the one sanctioned real-time-timer exception in the game.
model Expedition {
  id         Int      @id @default(autoincrement())
  clanId     Int
  clan       Clan     @relation(fields: [clanId], references: [id], onDelete: Cascade)
  defKey     String   @db.VarChar(40) // template id in shared/clan-activities.js
  difficulty String   @db.VarChar(20)
  slots      Int
  rewardXp   Int
  rewardGold Int      // total gold pot, split across participants on resolve
  powerReq   Int
  startedBy  Int? // userId of the launcher (may cancel their own run)
  status     String   @default("active") @db.VarChar(20) // active | resolved | cancelled
  success    Boolean?
  startedAt  DateTime @default(now())
  endsAt     DateTime
  resolvedAt DateTime?
  createdAt  DateTime @default(now())

  members ExpeditionMember[]

  @@index([clanId, status])
}

model ExpeditionMember {
  id           Int        @id @default(autoincrement())
  expeditionId Int
  expedition   Expedition @relation(fields: [expeditionId], references: [id], onDelete: Cascade)
  userId       Int
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  power        Int        @default(0) // gear power snapshot at registration (anti-cheat)
  joinedAt     DateTime   @default(now())

  @@unique([expeditionId, userId])
  @@index([expeditionId])
}

// A clan goal tracked from real play (forge N, defeat N, win N bosses, ...). Progress
// is contributed by every member's play; completion grants clan XP once.
model Mission {
  id        Int      @id @default(autoincrement())
  clanId    Int
  clan      Clan     @relation(fields: [clanId], references: [id], onDelete: Cascade)
  defKey    String   @db.VarChar(40)
  type      String   @db.VarChar(30) // forge_count | defeat_enemies | win_bosses | swap_all_gear | reach_arena
  target    Int
  progress  Int      @default(0)
  rewardXp  Int
  status    String   @default("active") @db.VarChar(20) // active | completed
  startedAt DateTime @default(now())
  expiresAt DateTime?

  contributions MissionContribution[]

  @@index([clanId, status])
}

model MissionContribution {
  id        Int     @id @default(autoincrement())
  missionId Int
  mission   Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  userId    Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int     @default(0)

  @@unique([missionId, userId])
  @@index([missionId])
}

model GameState {
  id                Int      @id @default(autoincrement())
  userId            Int      @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  equipment         Json     @default("{}")
  gold              Int      @default(100)
  forgeLevel        Int      @default(1)
  forgeUpgrade      Json?
  combat            Json     @default("{\"currentWave\":1,\"currentSubWave\":1,\"highestWave\":1,\"highestSubWave\":1}")
  essence           Int      @default(0)
  diamonds          Int      @default(100)
  player            Json     @default("{\"level\":1,\"xp\":0,\"profilePicture\":\"wizard\"}")
  research          Json     @default("{\"completed\":{},\"active\":null,\"queue\":[]}")
  forgeHighestLevel Json     @default("{}")
  skills            Json     @default("{\"unlocked\":{},\"equipped\":[]}")
  updatedAt         DateTime @updatedAt
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  senderId  Int
  sender    User     @relation("sender", fields: [senderId], references: [id], onDelete: Cascade)
  // Logical channel. Built-ins: "general". Clan chat: "clan:<clanId>".
  // Private DMs / custom groups: "conv:<conversationId>".
  channel   String   @default("general") @db.VarChar(50)
  content   String   @db.VarChar(500)
  createdAt DateTime @default(now())

  @@index([channel, createdAt])
  @@index([senderId])
}

// A private conversation: a 1:1 direct message ("dm") or a named custom group
// ("group"). Messages are stored as ChatMessage rows with channel "conv:<id>".
model Conversation {
  id        Int      @id @default(autoincrement())
  type      String   @default("dm") @db.VarChar(10) // dm | group
  name      String?  @db.VarChar(40) // group name (null for dms)
  createdBy Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members ConversationMember[]

  @@index([updatedAt])
}

model ConversationMember {
  id             Int          @id @default(autoincrement())
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         Int
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt       DateTime     @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Ban {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation("bannedUser", fields: [userId], references: [id], onDelete: Cascade)
  reason    String    @db.VarChar(500)
  issuedBy  Int
  expiresAt DateTime? // null = permanent
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())

  @@index([userId, active])
}

model Mute {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation("mutedUser", fields: [userId], references: [id], onDelete: Cascade)
  reason    String   @db.VarChar(500)
  issuedBy  Int
  expiresAt DateTime
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([userId, active])
}

model Warning {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation("warnedUser", fields: [userId], references: [id], onDelete: Cascade)
  reason    String   @db.VarChar(500)
  issuedBy  Int
  issuer    User     @relation("warningIssuer", fields: [issuedBy], references: [id])
  createdAt DateTime @default(now())

  @@index([userId])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  actorId   Int
  actor     User     @relation("auditActor", fields: [actorId], references: [id])
  action    String   @db.VarChar(50)
  targetId  Int?
  details   Json?
  createdAt DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([targetId])
}

model SpriteSheet {
  id       Int               @id @default(autoincrement())
  type     String            @unique @db.VarChar(30) // hat, weapon, armor, ..., monster, player
  file     String            @db.VarChar(200) // /assets/helmets.png
  width    Int
  height   Int
  items    ItemTemplate[]
  sprites  Sprite[]          @relation("SpriteSheetSprites")
  monsters MonsterTemplate[]
  players  PlayerTemplate[]
}

model Sprite {
  id            Int               @id @default(autoincrement())
  name          String            @db.VarChar(100)
  spriteX       Int
  spriteY       Int
  spriteW       Int
  spriteH       Int
  spriteSheetId Int
  spriteSheet   SpriteSheet       @relation("SpriteSheetSprites", fields: [spriteSheetId], references: [id])
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  items         ItemTemplate[]
  monsters      MonsterTemplate[]
  players       PlayerTemplate[]

  @@index([spriteSheetId])
}

model ItemTemplate {
  id            Int         @id @default(autoincrement())
  type          String      @db.VarChar(30) // hat, weapon, armor, etc.
  tier          Int // 1-7
  skin          String      @unique @db.VarChar(50)
  name          String      @db.VarChar(100)
  spriteId      Int?
  sprite        Sprite?     @relation(fields: [spriteId], references: [id])
  spriteX       Int?
  spriteY       Int?
  spriteW       Int?
  spriteH       Int?
  spriteSheetId Int
  spriteSheet   SpriteSheet @relation(fields: [spriteSheetId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([type, tier])
}

model Purchase {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSessionId String   @unique
  stripePaymentId String?
  packId          String   @db.VarChar(30)
  goldGranted     Int      @default(0) // default lets `prisma db push` add this column to pre-existing rows (e.g. legacy diamond purchases) without a force-reset; every real insert sets it explicitly
  amountCents     Int
  currency        String   @default("usd") @db.VarChar(10)
  status          String   @default("pending") @db.VarChar(20) // pending, completed, refunded
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status])
}

model MonsterTemplate {
  id            Int          @id @default(autoincrement())
  slug          String       @unique @db.VarChar(50) // e.g. "rat", "wolf", "spider"
  name          String       @db.VarChar(100) // Display name: "Rat", "Wolf"
  emoji         String       @db.VarChar(10) // Fallback emoji: "🐀"
  color         String       @db.VarChar(10) // Theme color hex: "#8d6e63"
  wave          Int // Wave index (1-20)
  hpMultiplier  Float        @default(1.0) // Per-monster HP modifier
  dmgMultiplier Float        @default(1.0) // Per-monster damage modifier
  speedModifier Int          @default(0) // Attack speed offset (ms)
  spriteId      Int?
  sprite        Sprite?      @relation(fields: [spriteId], references: [id])
  spriteSheetId Int?
  spriteSheet   SpriteSheet? @relation(fields: [spriteSheetId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([wave])
}

model PlayerTemplate {
  id            Int          @id @default(autoincrement())
  slug          String       @unique @db.VarChar(50) // e.g. "warrior", "mage"
  name          String       @db.VarChar(100) // Display name
  isDefault     Boolean      @default(false) // Default player skin
  spriteId      Int?
  sprite        Sprite?      @relation(fields: [spriteId], references: [id])
  spriteSheetId Int?
  spriteSheet   SpriteSheet? @relation(fields: [spriteSheetId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}
